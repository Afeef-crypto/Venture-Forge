# Backend — see backend/.env.example for all keys

# Global fallback
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Per-agent keys (optional)
OPENROUTER_KEY_YC=
OPENROUTER_KEY_TECH=
OPENROUTER_KEY_BIZ=
OPENROUTER_KEY_MKT=
OPENROUTER_KEY_DEM=
OPENROUTER_KEY_SYNTHESIS=

CORS_ORIGINS=http://localhost:8086,http://127.0.0.1:8086
RATE_LIMIT_SECONDS=30

