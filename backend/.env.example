# Global fallback (used when a per-agent key is not set)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Per-agent OpenRouter keys (optional — override fallback per agent)
OPENROUTER_KEY_YC=
OPENROUTER_KEY_TECH=
OPENROUTER_KEY_BIZ=
OPENROUTER_KEY_MKT=
OPENROUTER_KEY_DEM=
OPENROUTER_KEY_SYNTHESIS=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_SECONDS=30
